{
  "name": "syncflow",
  "private": true,
  "version": "0.0.1",
  "description": "A powerful and easy-to-use file synchronization tool",
  "author": "Aengus",
  "productName": "SyncFlow",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && cross-env NODE_ENV=development electron .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc -b --noEmit",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@types/node": "^22.19.8",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.24",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "framer-motion": "^12.31.2",
    "globals": "^16.0.0",
    "i18next": "^25.8.4",
    "lucide-react": "^0.511.0",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wait-on": "^9.0.3",
    "zustand": "^5.0.3"
  },
  "build": {
    "productName": "SyncFlow",
    "appId": "top.aengus.filesync",
    "asar": {
      "smartUnpack": true
    },
    "directories": {
      "output": "release/${version}",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "asarUnpack": [
      "**/*.node"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "bundleVersion": "1.0.0",
      "category": "public.app-category.utilities",
      "icon": "public/icon.png",
      "extendInfo": {
        "CFBundleName": "SyncFlow",
        "CFBundleDisplayName": "SyncFlow"
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-setup.${ext}",
      "icon": "public/icon.png",
      "executableName": "SyncFlow"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "category": "Utility",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
